{
  "manifest_version": 3,
  "name": "Brain Rot Counter",
  "version": "2.1.0",
  "description": "Counts Instagram Reels and YouTube Shorts you watch, syncs with the BrainRot portal and lets you compete with friends.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Brain Rot Counter"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["https://api.brainrot.quicklabs.pro/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": ["content.js"],
      "css": ["popup.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://brainrot.quicklabs.pro/*"],
      "js": ["connect.js"],
      "run_at": "document_idle"
    }
  ]
}
